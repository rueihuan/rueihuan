{
  "extends": "@tsconfig/strictest/tsconfig",
  "compilerOptions": {
    /* Visit https://aka.ms/tsconfig.json to read more about this file */

    /* Modules */
    "module": "es2022", // REVIEW
    "moduleResolution": "bundler", // REVIEW
    "resolveJsonModule": true,
    "types": ["node"], // REVIEW

    /* Emit */
    "removeComments": true,
    "sourceMap": true,

    /* JavaScript Support */
    "allowJs": true,
    "checkJs": true,

    /* Interop Constraints */
    "esModuleInterop": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* Language and Environment */
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "jsx": "preserve", // REVIEW
    "lib": ["es2022", "dom", "dom.iterable"], // REVIEW
    "moduleDetection": "force",
    "target": "es2022", // REVIEW

    /* Completeness */
    "skipLibCheck": true,

    /* Overrides */
    "baseUrl": "./", // REVIEW
    // "paths": {
    //   "~/*": ["src/*"]
    // },
    "outDir": "./tmp"
  }
}
